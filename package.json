{
    "name": "gitlab-issues",
    "displayName": "Gitlab issues",
    "description": "issues for users and groups",
    "publisher": "Danil",
    "version": "1.7.0",
    "icon": "assets/icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "repository": {
        "url": "https://github.com/Finist02/gitlab-issues",
        "type": "git"
    },
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "gitlab-issues",
                    "title": "Gitlab Issues",
                    "icon": "$(issues)"
                }
            ]
        },
        "views": {
            "gitlab-issues": [
                {
                    "id": "UsersGitlab",
                    "name": "Users Gitlab",
                    "icon": "$(person)",
                    "contextualTitle": "Gitlab Users Explorer",
                    "canSelectMany": false
                },
                {
                    "id": "FavoritesGitlab",
                    "name": "Favorites Gitlab",
                    "icon": "$(star)",
                    "contextualTitle": "Gitlab Favorites Explorer",
                    "canSelectMany": false
                }
            ]
        },
        "commands": [
            {
                "command": "UsersGitlab.viewIssues",
                "title": "GitLab Issues: 📊 Show user issues",
                "icon": "$(graph)"
            },
            {
                "command": "UsersGitlab.addToFavorites",
                "title": "GitLab Issues: ⭐ Add to Favorites",
                "icon": "$(star)"
            },
            {
                "command": "FavoritesGitlab.removeFromFavorites",
                "title": "GitLab Issues: ⭐ Remove from Favorites",
                "icon": "$(star-full)"
            },
            {
                "command": "UsersGitlab.refreshEntry",
                "title": "GitLab Issues: Refresh users tree",
                "icon": "$(refresh)"
            },
            {
                "command": "FavoritesGitlab.refreshFavorites",
                "title": "GitLab Issues: Refresh favorites",
                "icon": "$(refresh)"
            },
            {
                "command": "UsersGitlab.exportDailyStandup",
                "title": "GitLab Issues: 📅 Export daily standup (Markdown)",
                "icon": "$(file-text)"
            },
            {
                "command": "UsersGitlab.exportProjectOverview",
                "title": "GitLab Issues: 📊 Export project overview (Markdown)",
                "icon": "$(graph)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "UsersGitlab.exportProjectOverview",
                    "when": "view == UsersGitlab",
                    "group": "navigation@2"
                },
                {
                    "command": "UsersGitlab.refreshEntry",
                    "when": "view == UsersGitlab",
                    "group": "navigation@1"
                },
                {
                    "command": "FavoritesGitlab.refreshFavorites",
                    "when": "view == FavoritesGitlab",
                    "group": "navigation@1"
                },
                {
                    "command": "UsersGitlab.exportDailyStandup",
                    "when": "view == FavoritesGitlab",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "UsersGitlab.addToFavorites",
                    "when": "view == UsersGitlab && viewItem == user",
                    "group": "inline"
                },
                {
                    "command": "FavoritesGitlab.removeFromFavorites",
                    "when": "view == FavoritesGitlab && viewItem == favorite-item",
                    "group": "inline"
                }
            ]
        },
        "configuration": {
            "title": "GitLab Issues",
            "properties": {
                "gitlabIssues.gitlabUrl": {
                    "type": "string",
                    "default": "",
                    "description": "GitLab instance URL",
                    "order": 0
                },
                "gitlabIssues.favoriteUsers": {
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "GitLab user id (для API assignee_id)"
                            },
                            "label": {
                                "type": "string",
                                "description": "Отображаемое имя"
                            }
                        }
                    },
                    "markdownDescription": "Избранные пользователи для панели Favorites и экспорта дэйлика. Можно править вручную или через **Add to Favorites** в дереве.",
                    "order": 1
                },
                "gitlabIssues.projectProfiles": {
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "Уникальный ключ профиля (латиница)"
                            },
                            "label": {
                                "type": "string",
                                "description": "Название в UI и статус-баре"
                            },
                            "gitlabProjectRefs": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "Пути `namespace/project` или id проекта GitLab"
                            }
                        }
                    },
                    "markdownDescription": "Логические проекты из **нескольких** репозиториев GitLab. Пример: `{ \"id\": \"mes\", \"label\": \"MES\", \"gitlabProjectRefs\": [\"group/front\", \"group/api\"] }`.",
                    "order": 2
                },
                "gitlabIssues.dailyExportFolder": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Папка для сохранения дэйлика (абсолютный путь или относительно корня workspace). Создаётся файл `Standup-YYYY-MM-DD.md`.",
                    "order": 3
                },
                "gitlabIssues.dailyTemplatePath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Необязательно: путь к `.md` шаблону. Плейсхолдеры: `{{date}}`, `{{dateLong}}`, `{{dateHuman}}`, `{{currentTasksByUser}}` (задачи «в процессе» по лейблам как в Gantt), `{{gitlabIssuesByUser}}`. Если пусто — встроенный шаблон.",
                    "order": 4
                },
                "gitlabIssues.projectExportFolder": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Базовая папка для **обзора проекта**: внутри создаётся подпапка с **id профиля**, файл — только дата: `{base}/{id}/YYYY-MM-DD.md`. Если пусто — используется `dailyExportFolder`.",
                    "order": 5
                },
                "gitlabIssues.ganttLabelsDone": {
                    "type": "array",
                    "default": [],
                    "items": { "type": "string" },
                    "markdownDescription": "Имена лейблов GitLab → статус Mermaid **done** в Gantt. **Пустой массив** — встроенный набор: `Отработано`, `Отработано: развернуто`, `UnderValidation`.",
                    "order": 6
                },
                "gitlabIssues.ganttLabelsActive": {
                    "type": "array",
                    "default": [],
                    "items": { "type": "string" },
                    "markdownDescription": "Имена лейблов → **active** в Gantt. **Пустой массив** — по умолчанию: `В процессе`.",
                    "order": 7
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/mocha": "^10.0.7",
        "@types/node": "20.x",
        "@typescript-eslint/eslint-plugin": "^8.3.0",
        "@typescript-eslint/parser": "^8.3.0",
        "eslint": "^9.9.1",
        "typescript": "^5.5.4",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1"
    },
    "dependencies": {
        "axios": "^1.12.0"
    },
    "license": "MIT"
}